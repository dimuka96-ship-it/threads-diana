# Скопируйте в .env и заполните. Для генерации постов через Gemini:
GEMINI_API_KEY=...
# Необязательно — модель генерации (по умолчанию gemini-3.5-flash):
# GEMINI_MODEL=gemini-3.5-flash

# Threads API. App ID и App Secret — в приложении: App settings → Basic.
THREADS_APP_ID=
THREADS_APP_SECRET=
# Эти два заполнит src/auth.js автоматически после обмена кода:
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=
# Необязательно (по умолчанию https://localhost/):
# THREADS_REDIRECT_URI=https://localhost/
